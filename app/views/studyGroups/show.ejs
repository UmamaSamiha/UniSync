<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= group.name %> | UniSync</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="top-nav">
    <div class="nav-brand">✦ UniSync</div>
    <a href="/study-groups" class="btn btn-secondary">← All Groups</a>
  </div>

  <div class="container">
    <div class="group-header">
      <span class="badge"><%= group.subject %></span>
      <h1><%= group.name %></h1>
      <p><%= group.description || 'No description provided.' %></p>
      <small>Created by <strong><%= group.created_by %></strong></small>
    </div>

    <div class="two-col">
      <!-- Members -->
      <div class="section">
        <div class="section-header">
          <h2>👥 Members (<%= members.length %>)</h2>
          <a href="/study-groups/<%= group.id %>/join" class="btn btn-sm">+ Join</a>
        </div>

        <% if (members.length === 0) { %>
          <p class="empty">No members yet — be the first!</p>
        <% } else { %>
          <% members.forEach(member => { %>
            <div class="member-card">
              <div class="member-avatar"><%= member.student_name.charAt(0).toUpperCase() %></div>
              <div class="member-info">
                <strong><%= member.student_name %></strong>
                <span class="member-id">ID: <%= member.student_id %></span>
                <span>📚 <%= member.major %> — <%= member.semester %> Sem</span>
                <span>🎯 <%= member.subject_interest %></span>
                <span>📧 <%= member.email %></span>
                <span>📞 <%= member.contact %></span>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- Posts -->
      <div class="section">
        <div class="section-header">
          <h2>📝 Posts (<%= posts.length %>)</h2>
          <a href="/study-groups/<%= group.id %>/posts/create" class="btn btn-sm">+ Post</a>
        </div>

        <% if (posts.length === 0) { %>
          <p class="empty">Nothing here yet — start a discussion!</p>
        <% } else { %>
          <% posts.forEach(post => { %>
            <a href="/study-groups/<%= group.id %>/posts/<%= post.id %>" class="post-link">
              <div class="post-card">
                <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:6px;">
                  <div class="post-type <%= post.type %>">
                    <%= post.type === 'task' ? '📋 TASK' :
                        post.type === 'discussion' ? '💬 DISCUSSION' :
                        post.type === 'bigbrain' ? '🧠 BIG BRAIN' : '💀 BRAINROT' %>
                  </div>
                  <% if (post.type === 'task') { %>
                    <div class="status-badge status-<%= post.status %>">
                      <%= post.status === 'pending' ? '🕐 Pending' :
                          post.status === 'in_progress' ? '⚡ In Progress' : '✅ Done' %>
                    </div>
                  <% } %>
                </div>
                <h3><%= post.title %></h3>
                <p><%= post.content.length > 100 ? post.content.substring(0, 100) + '...' : post.content %></p>
                <div class="post-footer">
                  <small>✍️ <strong><%= post.posted_by %></strong></small>
                  <% if (post.assigned_to) { %><small>👤 <%= post.assigned_to %></small><% } %>
                  <% if (post.due_date) { %><small>📅 <%= new Date(post.due_date).toDateString() %></small><% } %>
                </div>
              </div>
            </a>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>