<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Create Group | UniSync</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="top-nav">
    <div class="nav-brand">✦ UniSync</div>
    <a href="/study-groups" class="btn btn-secondary">← Back</a>
  </div>

  <div class="container">
    <div class="form-card">
      <div class="form-title">
        <h1>Create a Study Group</h1>
        <p>Start something great — invite your classmates to join you.</p>
      </div>

      <% if (error) { %>
        <p class="error">⚠️ <%= error %></p>
      <% } %>

      <form action="/study-groups" method="POST">
        <div class="form-group">
          <label>Group Name <span class="req">★</span></label>
          <input type="text" name="name" placeholder="e.g. Software Engineering Study Squad" required />
        </div>

        <div class="form-group">
          <label>Subject <span class="req">★</span></label>
          <input type="text" name="subject" placeholder="e.g. Computer Science" required />
        </div>

        <div class="form-group">
          <label>Description</label>
          <textarea name="description" rows="4" placeholder="What will this group focus on?"></textarea>
        </div>

        <div class="form-group">
          <label>Your Name <span class="req">★</span></label>
          <input type="text" name="created_by" placeholder="e.g. Kim Seokjin" required />
        </div>

        <button type="submit" class="btn btn-full">🚀 Create Group</button>
      </form>
    </div>
  </div>
</body>
</html>